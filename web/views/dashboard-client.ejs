<%- include('./partials/header') %>

<div class="d-flex justify-content-between align-items-center mb-4">
  <h2 class="fw-bold">Client Dashboard</h2>
  <a href="/jobs/new" class="btn btn-primary shadow-sm">+ Post a New Job</a>
</div>

<div class="row">
  <div class="col-lg-5 mb-4">
    <div class="card p-0 h-100">
      <div class="card-header bg-light">
        <h5 class="mb-0 fw-bold">Your Posted Jobs</h5>
      </div>
      <div class="card-body">
        <% if(jobs && jobs.length > 0) { %>
          <div class="list-group list-group-flush">
            <% jobs.forEach(job => { %>
              <a href="/jobs/<%= job._id %>" class="list-group-item list-group-item-action py-3 border-bottom">
                <div class="d-flex w-100 justify-content-between align-items-center mb-1">
                  <h6 class="mb-0 fw-bold text-primary"><%= job.title %></h6>
                  <span class="badge status-<%= job.status.replace(' ', '') %>"><%= job.status %></span>
                </div>
                <small class="text-muted">Budget: $<%= job.budget %></small>
              </a>
            <% }) %>
          </div>
        <% } else { %>
          <p class="text-muted mb-0">You haven't posted any jobs yet.</p>
        <% } %>
      </div>
    </div>
  </div>
  
  <div class="col-lg-7 mb-4">
    <div class="card p-0 h-100">
      <div class="card-header bg-light">
        <h5 class="mb-0 fw-bold">Recent Proposals Received</h5>
      </div>
      <div class="card-body">
        <% if(proposals && proposals.length > 0) { %>
          <div class="table-responsive">
            <table class="table table-hover align-middle">
              <thead>
                <tr>
                  <th>Job Title</th>
                  <th>Freelancer</th>
                  <th>Bid</th>
                  <th>Status</th>
                  <th>Action</th>
                </tr>
              </thead>
              <tbody>
                <% proposals.forEach(p => { %>
                  <tr>
                    <td><a href="/jobs/<%= p.job._id %>" class="text-decoration-none fw-bold"><%= p.job.title %></a></td>
                    <td><%= p.freelancer.name %></td>
                    <td class="fw-semibold text-success">$<%= p.bidAmount %></td>
                    <td>
                      <span class="badge bg-<%= p.status === 'Accepted' ? 'success' : p.status === 'Rejected' ? 'danger' : 'secondary' %>">
                        <%= p.status %>
                      </span>
                    </td>
                    <td>
                      <a href="/jobs/<%= p.job._id %>" class="btn btn-sm btn-outline-primary">View Job</a>
                    </td>
                  </tr>
                <% }) %>
              </tbody>
            </table>
          </div>
        <% } else { %>
          <p class="text-muted mb-0">No proposals received yet.</p>
        <% } %>
      </div>
    </div>
  </div>
</div>

<%- include('./partials/footer') %>
