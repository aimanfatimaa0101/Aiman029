<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= typeof title !== 'undefined' ? title : 'SkillLink' %></title>
  <!-- Bootstrap 5 CSS -->
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
  <!-- Custom CSS -->
  <link rel="stylesheet" href="/css/style.css">
  <!-- Google Fonts - Inter -->
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;600;700&display=swap" rel="stylesheet">
</head>
<body>
  <nav class="navbar navbar-expand-lg navbar-dark bg-dark sticky-top shadow">
    <div class="container">
      <a class="navbar-brand fw-bold" href="/">SkillLink</a>
      <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbars">
        <span class="navbar-toggler-icon"></span>
      </button>
      <div class="collapse navbar-collapse" id="navbars">
        <ul class="navbar-nav me-auto">
          <li class="nav-item"><a class="nav-link" href="/jobs">Browse Jobs</a></li>
        </ul>
        <ul class="navbar-nav ms-auto align-items-center">
          <% if(session && session.userId) { %>
            <li class="nav-item me-3"><span class="text-light">Hi, <%= session.name %></span></li>
            <li class="nav-item"><a class="nav-link" href="/dashboard">Dashboard (<%= session.role %>)</a></li>
            <li class="nav-item"><a class="nav-link text-danger" href="/logout">Logout</a></li>
          <% } else { %>
            <li class="nav-item"><a class="nav-link" href="/login">Log In</a></li>
            <li class="nav-item ms-2"><a class="btn btn-primary btn-sm px-3 shadow" href="/register">Sign Up</a></li>
          <% } %>
        </ul>
      </div>
    </div>
  </nav>
  <main class="container my-4 flex-grow-1">
    <%- include('./messages') %>
