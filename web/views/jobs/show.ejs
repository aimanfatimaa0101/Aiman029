<%- include('../partials/header') %>

<div class="row justify-content-center">
  <div class="col-lg-10">
    <div class="card border-0 shadow-sm mb-4">
      <div class="card-header bg-white d-flex justify-content-between align-items-center py-3">
        <h3 class="mb-0 fw-bold"><%= job.title %></h3>
        <span class="badge fs-6 status-<%= job.status.replace(' ', '') %> shadow-sm px-3 py-2"><%= job.status %></span>
      </div>
      <div class="card-body p-4 bg-light">
        <div class="row mb-4">
          <div class="col-md-8">
            <h5 class="fw-bold text-muted mb-2">Job Description</h5>
            <p style="white-space: pre-wrap;" class="fs-5"><%= job.description %></p>
          </div>
          <div class="col-md-4 border-start">
            <div class="mb-3">
              <h6 class="fw-bold text-muted mb-1">Budget</h6>
              <h4 class="text-success fw-bold">$<%= job.budget %></h4>
            </div>
            <div class="mb-3">
              <h6 class="fw-bold text-muted mb-1">Posted By</h6>
              <p class="mb-0 fw-semibold"><%= job.createdBy.name %></p>
              <small class="text-muted"><%= job.createdBy.email %></small>
            </div>
            <div>
              <h6 class="fw-bold text-muted mb-1">Posted On</h6>
              <p class="mb-0 text-muted"><%= new Date(job.createdAt).toLocaleDateString() %></p>
            </div>
          </div>
        </div>

        <% if(session && session.userId === job.createdBy._id.toString()) { %>
          <div class="d-flex gap-2">
            <a href="/jobs/<%= job._id %>/edit" class="btn btn-warning shadow-sm fw-bold px-4">Edit Job</a>
            <form action="/jobs/<%= job._id %>?_method=DELETE" method="POST" onsubmit="return confirm('Are you sure you want to delete this job?');">
              <button type="submit" class="btn btn-danger shadow-sm fw-bold px-4">Delete Job</button>
            </form>
          </div>
        <% } %>
      </div>
    </div>

    <!-- For Clients: View Proposals -->
    <% if(session && session.userId === job.createdBy._id.toString()) { %>
      <h4 class="fw-bold mb-3 mt-5">Proposals (<%= proposals.length %>)</h4>
      <% if(proposals && proposals.length > 0) { %>
        <div class="row">
          <% proposals.forEach(p => { %>
            <div class="col-12 mb-3">
              <div class="card border-0 shadow-sm p-3 <%= p.status === 'Accepted' ? 'border-success border-2 bg-success bg-opacity-10' : '' %>">
                <div class="d-flex justify-content-between align-items-center mb-2">
                  <h5 class="fw-bold mb-0"><%= p.freelancer.name %> <small class="text-muted fw-normal fs-6">(<%= p.freelancer.email %>)</small></h5>
                  <h4 class="text-success fw-bold mb-0">Bid: $<%= p.bidAmount %></h4>
                </div>
                <p class="mb-3 text-muted" style="white-space: pre-wrap;"><%= p.coverLetter %></p>
                <div class="d-flex justify-content-between align-items-center">
                  <span class="badge fs-6 bg-<%= p.status === 'Accepted' ? 'success' : p.status === 'Rejected' ? 'danger' : 'secondary' %> shadow-sm">
                    Status: <%= p.status %>
                  </span>
                  <% if(p.status === 'Pending' && job.status === 'Open') { %>
                    <div class="d-flex gap-2">
                      <form action="/proposals/update/<%= p._id %>" method="POST">
                        <input type="hidden" name="action" value="Accept">
                        <button type="submit" class="btn btn-sm btn-success fw-bold shadow-sm px-3">Accept Bid</button>
                      </form>
                      <form action="/proposals/update/<%= p._id %>" method="POST">
                        <input type="hidden" name="action" value="Reject">
                        <button type="submit" class="btn btn-sm btn-danger fw-bold shadow-sm px-3">Reject</button>
                      </form>
                    </div>
                  <% } %>
                </div>
              </div>
            </div>
          <% }) %>
        </div>
      <% } else { %>
        <p class="text-muted">No proposals submitted yet.</p>
      <% } %>
    <% } %>

    <!-- For Freelancers: Submit Proposal -->
    <% if(session && session.role === 'Freelancer') { %>
      <% if(job.status !== 'Open') { %>
        <div class="alert alert-warning shadow-sm mt-4 fw-bold">This job is no longer open for new proposals.</div>
      <% } else if(hasApplied) { %>
        <div class="alert alert-success shadow-sm mt-4 fw-bold">You have already submitted a proposal for this job. Check your dashboard for status updates.</div>
      <% } else { %>
        <div class="card border-0 shadow-sm mt-5">
          <div class="card-header bg-white py-3">
            <h4 class="mb-0 fw-bold text-primary">Submit a Proposal</h4>
          </div>
          <div class="card-body p-4 bg-light">
            <form action="/proposals/<%= job._id %>" method="POST">
              <div class="mb-3">
                <label class="form-label fw-bold">Bid Amount ($)</label>
                <input type="number" name="bidAmount" class="form-control" required placeholder="e.g. <%= job.budget %>">
              </div>
              <div class="mb-3">
                <label class="form-label fw-bold">Cover Letter</label>
                <textarea name="coverLetter" class="form-control" rows="5" required placeholder="Explain why you are the best fit for this project..."></textarea>
              </div>
              <button type="submit" class="btn btn-primary fw-bold shadow-sm px-4 py-2">Submit Proposal</button>
            </form>
          </div>
        </div>
      <% } %>
    <% } %>

    <!-- For Guests -->
    <% if(!session || !session.userId) { %>
      <div class="alert alert-info shadow-sm mt-4 text-center p-4">
        <h5 class="fw-bold text-dark mb-3">Want to apply for this job?</h5>
        <a href="/login" class="btn btn-outline-primary fw-bold px-4 shadow-sm me-2">Log In</a>
        <span class="text-muted">or</span>
        <a href="/register" class="btn btn-primary fw-bold px-4 shadow-sm ms-2">Sign Up</a>
      </div>
    <% } %>

  </div>
</div>

<%- include('../partials/footer') %>
