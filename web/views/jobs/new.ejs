<%- include('../partials/header') %>

<div class="row justify-content-center">
  <div class="col-md-8">
    <div class="card border-0 shadow p-4">
      <h3 class="fw-bold mb-4 text-center">Post a New Job</h3>
      <form action="/jobs" method="POST">
        <div class="mb-3">
          <label class="form-label fw-semibold">Job Title</label>
          <input type="text" name="title" class="form-control" required placeholder="e.g. Need a Full Stack Developer">
        </div>
        <div class="mb-3">
          <label class="form-label fw-semibold">Description</label>
          <textarea name="description" class="form-control" rows="6" required placeholder="Describe the requirements in detail..."></textarea>
        </div>
        <div class="mb-4">
          <label class="form-label fw-semibold">Budget ($)</label>
          <input type="number" name="budget" class="form-control" required placeholder="e.g. 500">
        </div>
        <button type="submit" class="btn btn-primary w-100 py-2 fw-bold shadow-sm">Post Job</button>
      </form>
    </div>
  </div>
</div>

<%- include('../partials/footer') %>
