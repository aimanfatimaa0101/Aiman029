<%- include('../partials/header') %>

<div class="row justify-content-center">
  <div class="col-md-8">
    <div class="card border-0 shadow p-4 mb-5">
      <h3 class="fw-bold mb-4 text-center">Edit Job</h3>
      <form action="/jobs/<%= job._id %>?_method=PUT" method="POST">
        <div class="mb-3">
          <label class="form-label fw-semibold">Job Title</label>
          <input type="text" name="title" class="form-control" required value="<%= job.title %>">
        </div>
        <div class="mb-3">
          <label class="form-label fw-semibold">Description</label>
          <textarea name="description" class="form-control" rows="6" required><%= job.description %></textarea>
        </div>
        <div class="mb-3">
          <label class="form-label fw-semibold">Budget ($)</label>
          <input type="number" name="budget" class="form-control" required value="<%= job.budget %>">
        </div>
        <div class="mb-4">
          <label class="form-label fw-semibold">Status</label>
          <select name="status" class="form-select">
            <option value="Open" <%= job.status === 'Open' ? 'selected' : '' %>>Open</option>
            <option value="In Progress" <%= job.status === 'In Progress' ? 'selected' : '' %>>In Progress</option>
            <option value="Completed" <%= job.status === 'Completed' ? 'selected' : '' %>>Completed</option>
          </select>
        </div>
        <div class="d-flex gap-2">
          <button type="submit" class="btn btn-primary w-50 py-2 fw-bold shadow-sm">Update Job</button>
          <a href="/jobs/<%= job._id %>" class="btn btn-outline-secondary w-50 py-2 fw-bold shadow-sm">Cancel</a>
        </div>
      </form>
    </div>
  </div>
</div>

<%- include('../partials/footer') %>
