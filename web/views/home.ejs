<%- include('./partials/header') %>

<div class="hero-section mt-3">
  <h1>Welcome to SkillLink</h1>
  <p>The premium marketplace connecting world-class Freelancers with forward-thinking Clients.</p>
  <% if(!session || !session.userId) { %>
    <a href="/register" class="btn btn-light btn-lg px-5 fw-bold text-primary shadow">Join Now</a>
  <% } else { %>
    <a href="/dashboard" class="btn btn-light btn-lg px-5 fw-bold text-primary shadow">Go to Dashboard</a>
  <% } %>
</div>

<div class="row text-center mt-5 mb-4">
  <div class="col-md-4 mb-4">
    <div class="card h-100 p-4 bg-white">
      <h3 class="fw-bold text-primary mb-3">Post a Job</h3>
      <p class="text-muted">Clients can quickly post requirements and set a budget for their next big project.</p>
    </div>
  </div>
  <div class="col-md-4 mb-4">
    <div class="card h-100 p-4 bg-white">
      <h3 class="fw-bold text-primary mb-3">Submit Proposals</h3>
      <p class="text-muted">Freelancers can browse thousands of jobs, submit cover letters, and securely bid on projects.</p>
    </div>
  </div>
  <div class="col-md-4 mb-4">
    <div class="card h-100 p-4 bg-white">
      <h3 class="fw-bold text-primary mb-3">Secure Workflow</h3>
      <p class="text-muted">Easily track accepted proposals. Roles and statuses keep the workflow transparent and safe.</p>
    </div>
  </div>
</div>

<%- include('./partials/footer') %>
